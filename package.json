{
  "name": "acp-hydra-slack",
  "version": "0.1.0",
  "description": "Bridge acp-hydra sessions to Slack threads.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "acp-hydra-slack": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "start": "node dist/index.js",
    "dev": "tsc -p . && node dist/index.js",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "lint": "tsc -p . --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
